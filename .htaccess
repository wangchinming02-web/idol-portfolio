# .htaccess - 簡化版，先讓網站正常顯示（測試用）

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 強制 HTTPS（InfinityFree 支援）
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# 禁止目錄瀏覽
Options -Indexes

# 只保護特定敏感檔（不要擋所有 .php）
<FilesMatch "^(db_config\.php|config\.php|\.inc|\.sql)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# 防熱連結（改成你的域名）
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?yp1997\.infinityfree\.me [NC]
    RewriteRule \.(jpg|jpeg|png|gif|webp|svg)$ - [NC,F,L]
</IfModule>

# MIME 嗅探防護（通常安全）
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>